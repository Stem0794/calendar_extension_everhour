{
  "manifest_version": 3,
  "name": "Weekly Calendar Project Tracker",
  "version": "4.0.0",
  "description": "Track, color-code, and export your Google Calendar meetings and project hours by week or day.",
  "permissions": ["activeTab", "storage", "sidePanel", "notifications", "alarms"],
  "commands": {
    "log-all": {
      "suggested_key": { "default": "Alt+Shift+L" },
      "description": "Log all meetings to Everhour"
    },
    "refresh-events": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Refresh calendar events"
    }
  },
  "host_permissions": ["https://api.everhour.com/*"],
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
